{
  "name": "@wonseok-han/confluence-sync",
  "version": "0.2.0",
  "type": "module",
  "description": "Markdown 디렉토리를 Confluence Cloud 페이지로 단방향 동기화하는 수동 실행 도구",
  "bin": {
    "confluence-sync": "dist/sync.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "sync": "tsx src/sync.ts",
    "sync:dry": "tsx src/sync.ts --dry-run",
    "sync:rebuild": "tsx src/sync.ts --rebuild",
    "list": "tsx src/sync.ts --list"
  },
  "publishConfig": {
    "registry": "https://git.internal.example/api/v4/projects/0/packages/npm/"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
