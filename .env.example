# Confluence Cloud 동기화 설정 — 복사해서 .env 로 만들고 값 채우기
# (.env 는 .gitignore 로 커밋되지 않음)

# ⚠️ Scoped(스코프) API 토큰을 사용한다. Classic 토큰은 2026.3~5월에 만료됨.
# Scoped 토큰은 api.atlassian.com 엔드포인트를 쓴다(아래 형식 필수):
#   https://api.atlassian.com/ex/confluence/<CLOUD_ID>/wiki
# CLOUD_ID 확인: 브라우저에서 https://<도메인>.atlassian.net/_edge/tenant_info 접속 → "cloudId" 값
CONFLUENCE_BASE_URL=

# Atlassian 계정 이메일 (Basic auth: email:token)
CONFLUENCE_EMAIL=

# https://id.atlassian.com/manage-profile/security/api-tokens
# → "Create API token with scopes" → 앱 Confluence
# → 스코프: read:space:confluence, read:page:confluence, write:page:confluence
#   (이미지 첨부 시 read:content-details:confluence + write:attachment:confluence,
#    --rebuild 시 delete:page:confluence 추가)
CONFLUENCE_API_TOKEN=

# Space 키 (URL .../wiki/spaces/<여기>/... 에서 확인)
CONFLUENCE_SPACE_KEY=

# (선택) 모든 문서를 이 페이지의 자식으로 생성. 비우면 공간 최상위에 생성
CONFLUENCE_PARENT_PAGE_ID=

# 동기화할 루트 디렉토리 (필수, --base 인자로도 지정 가능)
# 절대경로 권장. 상대경로는 명령 실행 위치(cwd) 기준으로 해석된다.
CONFLUENCE_SYNC_BASE=
